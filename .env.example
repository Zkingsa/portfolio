# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CONTACT FORM SMTP MAIL SETTINGS
# Set these variables in your environment to receive real email transmissions.
# receiver email (where you get contact messages)
CONTACT_RECEIVER_EMAIL="siximbazekhaya@gmail.com"
# SMTP server host (e.g., smtp.gmail.com)
SMTP_HOST="smtp.gmail.com"
# SMTP server port (e.g., 465 for SSL or 587 for STARTTLS)
SMTP_PORT="465"
# SMTP username (e.g., your gmail address)
SMTP_USER=""
# SMTP password / App Password (e.g., your gmail app password)
SMTP_PASS=""

